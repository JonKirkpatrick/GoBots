# Required: set this to a strong random value.
BBS_DASHBOARD_ADMIN_KEY=change_this_to_a_long_random_secret

# Optional timezone for logs/process.
TZ=UTC

# Optional no-Go update path (download prebuilt binary from GitHub Releases).
# If BBS_BINARY_URL is set, it is used directly.
# Otherwise URL is built from owner/repo/tag + architecture-based asset name.
BBS_BINARY_URL=
BBS_RELEASE_OWNER=JonKirkpatrick
BBS_RELEASE_REPO=bbs
BBS_RELEASE_TAG=latest
BBS_RELEASE_ASSET=
